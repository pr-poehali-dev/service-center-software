{
  "tests": [
    {
      "name": "Login admin success",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "admin@nexus.ru", "password": "admin123"},
      "expectedStatus": 200,
      "expectedBody": {"session_id": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password returns 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "admin@nexus.ru", "password": "wrong"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me without session returns 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "me"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
